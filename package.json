{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "cp -r node_modules/@gouvfr/dsfr/dist/artwork public/",
    "dev": "bun --hot server.ts",
    "dev:server": "bun --watch src/server/server.ts",
    "build": "bun build src/client/main.tsx --outdir=dist/client --target=browser --minify --sourcemap",
    "start": "NODE_ENV=production bun server.ts",
    "typecheck": "tsc --noEmit",
    "preview:emails:server": "bun --hot src/emails/preview-server.ts"
  },
  "dependencies": {
    "@elastic/elasticsearch": "8",
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.6",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/openapi": "^1.4.13",
    "@elysiajs/server-timing": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@gouvfr/dsfr": "^1.14.3",
    "@highcharts/react": "^4.1.0",
    "@tanstack/react-form": "^1.27.7",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-table": "^8.21.3",
    "@vis.gl/react-maplibre": "^8.1.0",
    "classnames": "^2.5.1",
    "elysia": "^1.4.19",
    "highcharts": "^12.4.0",
    "maplibre-gl": "^5.15.0",
    "mongodb": "^7.0.0",
    "nuqs": "^2.8.6",
    "proj4": "^2.20.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "^7.11.0",
    "react-router-dom": "^7.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.3",
    "@types/bun": "1.3.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19"
  }
}
